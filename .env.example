# MyHumidor by CigarTV — environment configuration
# Copy this to .env.local and fill in your values.

# ─── MRSS FEED ────────────────────────────────────────────────────────────────
# Where the CigarTV channel manifest lives. For local dev, leave blank to use
# /public/feed.xml. In production, point this at your live feed URL.
NEXT_PUBLIC_MRSS_URL=

# ─── LIVE CHANNEL (Amagi playout) ─────────────────────────────────────────────
# The 24/7 CigarTV linear stream that runs on lounge TV sticks. HLS (.m3u8).
# The ad/consent macros (gdpr_consent, us_privacy, etc.) are appended by the
# TV-stick client at runtime — the base playlist plays fine without them.
NEXT_PUBLIC_LIVE_STREAM_URL=https://amg30862-amg30862c1-amgplt0065.playout.now3.amagi.tv/ts-us-e2-n2/playlist/amg30862-amg30862c1-amgplt0065/playlist.m3u8

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ─── MAPBOX ───────────────────────────────────────────────────────────────────
# Public access token for Cigar Maps. https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── BRAND ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=MyHumidor
NEXT_PUBLIC_BRAND_PARENT=CigarTV
